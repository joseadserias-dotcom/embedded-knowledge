---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Embedded-Knowledge, Inc — Solution Design for Complex Problems',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>
  </head>
  <body>
    <header role="banner">
      <div class="container header-inner">
        <a href="/" aria-label="Embedded-Knowledge home" class="logo">E&#8209;K</a>
        <nav aria-label="Main navigation">
          <a href="/about">About</a>
          <a href="/book">Book</a>
          <a href="/services">Services</a>
          <a href="/speaking">Speaking</a>
          <a href="/assessment">Assessment</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer role="contentinfo">
      <div class="container footer-inner">
        <p>&copy; 2024 Embedded-Knowledge, Inc. All Rights Reserved.</p>
        <nav aria-label="Footer navigation">
          <a href="/contact">Contact</a>
          <a href="/about">About</a>
          <a
            href="https://www.linkedin.com/company/embedded-knowledge"
            aria-label="Follow Embedded-Knowledge on LinkedIn"
            target="_blank"
            rel="noopener noreferrer"
          >LinkedIn</a>
          <a
            href="https://twitter.com/embeddedknow"
            aria-label="Follow Embedded-Knowledge on Twitter (X)"
            target="_blank"
            rel="noopener noreferrer"
          >Twitter (X)</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    background: var(--color-navy);
    padding: 1rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    color: white;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
  }

  nav a:hover {
    text-decoration: underline;
  }

  footer {
    background: var(--color-bg-light);
    border-top: 1px solid #dde2ec;
    padding: 2rem 0;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .footer-inner nav {
    display: flex;
    gap: 1.5rem;
  }

  .footer-inner nav a {
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .footer-inner nav a:hover {
    color: var(--color-accent);
  }
</style>
