---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Advising — Embedded-Knowledge, Inc"
  description="E-K leads your team through the entire solution-design process, from dissecting the problem to guiding stakeholders through implementation."
>
  <div class="page">
    <div class="container">
      <h1>Advising</h1>
      <p>
        E-K leads your team through the entire solution-design process: dissecting the problem,
        crafting the best solution, and guiding stakeholders through implementation.
      </p>
      <a href="/contact" class="btn-primary">Contact E-K</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 4rem 0;
  }

  .container {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-navy);
  }

  p {
    font-size: 1.05rem;
  }
</style>
