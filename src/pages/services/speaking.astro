---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Speaking — Embedded-Knowledge, Inc"
  description="Eduardo and Erica share their solution-design experiences with audiences around the world, leading workshops and speaking at conferences and MBA courses."
>
  <div class="page">
    <div class="container">
      <h1>Speaking</h1>
      <p>
        Eduardo and Erica share their solution-design experiences with audiences around the
        world, leading workshops and speaking at conferences and MBA courses.
      </p>
      <a href="/contact" class="btn-primary">Contact E-K</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 4rem 0;
  }

  .container {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-navy);
  }

  p {
    font-size: 1.05rem;
  }
</style>
