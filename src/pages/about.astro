---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Embedded-Knowledge, Inc"
  description="Meet J. Eduardo Campos and Erica W. Campos, founders of Embedded-Knowledge, Inc."
>
  <div class="page">
    <div class="container">
      <h1>About Us</h1>

      <section aria-labelledby="eduardo-heading">
        <h2 id="eduardo-heading">J. Eduardo Campos</h2>
        <p>
          J. Eduardo Campos leads Embedded-Knowledge, Inc., enabling organizations and
          entrepreneurs to design creative solutions for complex problems through unique value
          propositions, sound business strategies, and healthy partnerships. He has advised and
          coached managers and C-level executives from global corporations, private-equity-funded
          ventures, and billion-dollar startups. J. Eduardo is Hogan Certified and a BMY Certified
          Practitioner.
        </p>
        <p>
          B.S. in Computer Science – PUCCAMP – Brazil. Executive Education: Information and
          Communications Technology and Public Policy – Harvard University, JFK School of
          Government.
        </p>
      </section>

      <section aria-labelledby="erica-heading">
        <h2 id="erica-heading">Erica W. Campos</h2>
        <p>
          Erica W. Campos brings decades of experience in organizational leadership and solution
          design. Together with Eduardo, she has co-authored "From Problem Solving to Solution
          Design" and co-leads Embedded-Knowledge, Inc.'s consulting and training programs
          worldwide.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 4rem 0;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 2rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  p {
    max-width: 720px;
  }
</style>
