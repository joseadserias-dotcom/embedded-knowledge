---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Assessment — Embedded-Knowledge, Inc"
  description="Take the Solution Designing assessment to see how equipped your company is."
>
  <div class="page">
    <div class="container">
      <h1>Solution Designing Assessment</h1>
      <p>How equipped is your company for designing solutions that matter?</p>
      <p>
        This assessment helps business leaders evaluate their organization's readiness to design
        and implement sustainable solutions for complex problems.
      </p>
      <a href="/contact" class="btn-primary">Request the Assessment</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 4rem 0;
  }

  .container {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
  }
</style>
