---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Podcasts, Videos, PR & Media — Embedded-Knowledge, Inc"
  description="Eduardo and Erica Campos featured in media, Forbes contributions, podcasts, and video appearances."
>
  <div class="page">
    <div class="container">
      <h1>Podcasts, Videos, PR &amp; Media</h1>
      <p>
        Eduardo and Erica have been featured in media, contributed articles to Forbes and other
        publications, and shared their expertise through podcasts and video content.
      </p>
      <p>Keep updated with the most recent media hits and appearances.</p>
      <a href="/contact" class="btn-primary">Get in Touch for Media Inquiries</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 4rem 0;
  }

  .container {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
  }
</style>
